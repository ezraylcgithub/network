#!name=Surge Information
#!desc=信息面板

[Panel]
SurgePro_ReloadProfile = script-name=SurgePro_ReloadProfile,update-interval=60
IP-Check = script-name=IP-Check,title="节点信息",content="点击刷新",style=info,update-interval=600
IP-Risk = script-name=IP-Risk,title="IP 风险检测",content="点击刷新",style=info,update-interval=600
stream-all = script-name=stream-all,title="流媒体解锁检测",content="点击刷新",style=info,update-interval=3600

[Script]
SurgePro_ReloadProfile = type=generic,timeout=10,script-path=https://raw.githubusercontent.com/ezraylcgithub/network/main/SurgePro.js,argument=icon=paperplane.circle&color=#f6c970

IP-Check = type=generic,timeout=5,script-path=https://raw.githubusercontent.com/ezraylcgithub/network/main/IP-Check.js

IP-Risk = type=generic,timeout=8,script-path=https://raw.githubusercontent.com/ezraylcgithub/network/main/iprisk.js,argument=icon=exclamationmark.shield&color=#ff9f0a

stream-all = type=generic,timeout=15,script-path=https://raw.githubusercontent.com/ezraylcgithub/network/main/Stream-All.js
